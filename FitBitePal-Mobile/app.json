{
  "expo": {
    "name": "FitBitePal-Mobile",
    "slug": "FitBitePal-Mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fitbitepal.mobile",
      "buildNumber": "1.0.0",
      "infoPlist": {
        "NSCameraUsageDescription": "FitBite Pal需要访问相机来识别食物和分析运动姿态",
        "NSPhotoLibraryUsageDescription": "FitBite Pal需要访问相册来选择图片进行分析",
        "NSPhotoLibraryAddUsageDescription": "FitBite Pal需要保存训练照片到相册",
        "NSMicrophoneUsageDescription": "FitBite Pal需要访问麦克风来录制训练视频（可选）",
        "NSUserNotificationsUsageDescription": "FitBite Pal需要发送通知来提醒您训练和用餐",
        "UIBackgroundModes": [
          "remote-notification",
          "remote-notification"
        ]
      },
      "requireFullScreen": false
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.fitbitepal.mobile",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED",
        "SCHEDULE_EXACT_ALARM",
        "POST_NOTIFICATIONS",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED",
        "SCHEDULE_EXACT_ALARM",
        "POST_NOTIFICATIONS",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE"
      ],
      "usesCleartextTraffic": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "7ccfc653-9981-4c9f-8bb4-f85caf2fc1ab"
      }
    },
    "owner": "qiwahhh",
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true,
            "networkInspector": true
          }
        }
      ]
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/7ccfc653-9981-4c9f-8bb4-f85caf2fc1ab"
    }
  }
}
