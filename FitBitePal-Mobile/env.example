# ╔══════════════════════════════════════════════════════════════╗
# ║  FitBite Pal Mobile - 环境变量配置                            ║
# ║  复制此文件为 .env 并修改配置值                                 ║
# ╚══════════════════════════════════════════════════════════════╝

# ========================================
# 🔧 API 配置（必须修改）
# ========================================

# 后端 API 地址
# 
# 📌 如何获取你的电脑 IP:
#    Windows: 打开 CMD，输入 ipconfig，找到 IPv4 地址
#    Mac/Linux: 打开终端，输入 ifconfig
#
# 📌 示例:
#    - 本地测试: http://192.168.x.x:8080/api （把 x.x 换成你的 IP）
#    - Android 模拟器: http://10.0.2.2:8080/api
#    - iOS 模拟器: http://localhost:8080/api
#    - 云服务器: https://your-server.com/api
#
EXPO_PUBLIC_API_URL=http://你的电脑IP:8080/api

# ========================================
# 开发调试配置 (可选)
# ========================================

# 启用详细日志 (true/false)
EXPO_PUBLIC_DEBUG_MODE=false

# API 请求超时时间 (毫秒)
EXPO_PUBLIC_API_TIMEOUT=30000

# ========================================
# 功能开关 (可选)
# ========================================

# 启用 AI 姿态识别 (true/false)
EXPO_PUBLIC_POSE_ENABLED=true

# 启用 AI 食物识别 (true/false)
EXPO_PUBLIC_FOOD_AI_ENABLED=true

# ========================================
# 其他配置 (可选)
# ========================================

# 应用版本号 (与 app.json 保持一致)
EXPO_PUBLIC_APP_VERSION=1.0.0

