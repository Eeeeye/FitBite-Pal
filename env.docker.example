# FitBite Pal - Docker 环境变量配置
# 复制此文件为 .env 并修改配置值
# 用于 docker-compose.yml

# ========================================
# MySQL 数据库配置
# ========================================
MYSQL_ROOT_PASSWORD=999886
MYSQL_DATABASE=fitbitepal
MYSQL_PORT=3306

# ========================================
# Redis 配置
# ========================================
REDIS_PORT=6379

# ========================================
# 后端服务配置
# ========================================
BACKEND_PORT=8080

# JWT 密钥 (必须修改为安全的随机字符串，至少256位)
JWT_SECRET=this_is_a_local_dev_secret_key_for_fitbite_pal_learning_123456
JWT_EXPIRATION=86400000

# ========================================
# 邮件服务配置
# ========================================
MAIL_HOST=smtp.qq.com
MAIL_PORT=587
MAIL_USERNAME=2154339681@qq.com
MAIL_PASSWORD=your_email_authorization_code

# ========================================
# AI 服务配置 (可选)
# ========================================
MODELSCOPE_API_KEY=ms-64156097-3f56-4037-9b7f-b903ffb82418
MODELSCOPE_ENABLED=true

# ========================================
# 跨域配置 (生产环境)
# ========================================
CORS_ALLOWED_ORIGINS=*

